# Build from project root directory with:
#   docker build --platform linux/386 -t libusb_manylinux2014_i686 -f dockerfiles/Dockerfile_manylinux2014_i686 .
# Run with:
#   docker run --platform linux/386 -ti --rm --mount type=bind,source="$(pwd)",target=/mnt/bind-root libusb_manylinux2014_i686 <cmd goes here>
FROM quay.io/pypa/manylinux2014_i686:latest AS dev-base

# Do the build.
COPY libusb /root/libusb
RUN cd /root/libusb && ./autogen.sh --disable-udev
RUN cd /root/libusb && make -j4

# Create the bind-mount directory.
RUN mkdir -p /mnt/bind-root
WORKDIR /mnt/bind-root
